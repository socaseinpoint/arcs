#!/usr/bin/env bash
# arcs-status — scan arc.md / *-goal.md in a project, print a board.
# Usage: arcs-status [project-dir]   (default: cwd)
set -euo pipefail

ROOT="${1:-.}"
cd "$ROOT"

field() { grep -m1 -E "^$2:" "$1" 2>/dev/null | sed -E "s/^$2:[[:space:]]*//" || true; }

print_arc() {
  local md="$1" indent="$2"
  local name status goal
  name="$(dirname "$md" | xargs basename)"
  status="$(field "$md" status)"; goal="$(field "$md" goal)"
  printf "%s%-34s %-10s %s\n" "$indent" "$name" "[${status:-?}]" "${goal:-}"
}

# Goals (current version = highest-numbered *-goal.md per goal dir)
if [ -d goals ]; then
  echo "GOALS"
  for g in goals/*/; do
    [ -d "$g" ] || continue
    cur="$(ls "$g"/*-goal.md 2>/dev/null | sort | tail -1 || true)"
    if [ -n "$cur" ]; then
      printf "  %-32s %-10s %s\n" "$(basename "$g")" "[$(field "$cur" status)]" "$(field "$cur" goal)"
      echo "      ($(basename "$cur"))"
    fi
    for a in "$g"arcs/*/arc.md; do [ -f "$a" ] && print_arc "$a" "      "; done
  done
  echo
fi

# Root standalone arcs
if [ -d arcs ]; then
  echo "ARCS (root)"
  for a in arcs/*/arc.md; do [ -f "$a" ] && print_arc "$a" "  "; done
fi
