#!/usr/bin/env bash
# arcs — file-based work method CLI (arc + goal).
# Subcommands: init · new-arc · new-goal · close · reopen · supersede · candidate · promote · rule · status · lang · version · check-update · update · help
# Work lives in a hidden meta dir: .arcs/{arcs,candidates,rules}/ — arcs and goals share one numbered stream.
set -euo pipefail

# --- helpers ---------------------------------------------------------------
die() { echo "arcs: $*" >&2; exit 1; }

repo_dir() {   # absolute path of the arcs repo (this script lives in <repo>/bin)
  local src="${BASH_SOURCE[0]}" d
  while [ -h "$src" ]; do
    d="$(cd -P "$(dirname "$src")" && pwd)"; src="$(readlink "$src")"
    [[ $src != /* ]] && src="$d/$src"
  done
  cd -P "$(dirname "$src")/.." && pwd
}

base_dir() {   # echo the meta base: .arcs if present, else create it
  [ -d .arcs ] || mkdir -p .arcs/arcs
  echo ".arcs"
}

lang_of() {    # project's arc language from .arcs/config (default en)
  local l=""
  [ -f .arcs/config ] && l="$(grep -m1 '^lang=' .arcs/config 2>/dev/null | cut -d= -f2 || true)"
  echo "${l:-en}"
}

# Rules: bodies live globally in <repo>/rules/<slug>.md (a project may override in
# .arcs/rules/<slug>.md). The on/off switch is the `rules=` line in .arcs/config.
rules_on() {   # echo space-separated enabled rule slugs from .arcs/config
  local l=""
  [ -f .arcs/config ] && l="$(grep -m1 '^rules=' .arcs/config 2>/dev/null | cut -d= -f2 || true)"
  echo "$l" | tr ',' ' '
}
rule_is_on() { local s; for s in $(rules_on); do [ "$s" = "$1" ] && return 0; done; return 1; }
rule_body_path() {   # $1=slug -> path to its body (local override first, else global), or empty
  local repo; repo="$(repo_dir)"
  if   [ -f ".arcs/rules/$1.md" ]; then echo ".arcs/rules/$1.md"
  elif [ -f "$repo/rules/$1.md" ];  then echo "$repo/rules/$1.md"
  else echo ""; fi
}
config_set_rules() {   # $1 = new comma list (may be empty)
  local tmp; tmp="$(mktemp)"
  if grep -q '^rules=' .arcs/config 2>/dev/null; then
    sed "s/^rules=.*/rules=$1/" .arcs/config > "$tmp" && mv "$tmp" .arcs/config
  else printf 'rules=%s\n' "$1" >> .arcs/config; fi
}

next_num() {   # next zero-padded NN — counts open NN-<slug>/ AND closed __NN-<slug>__/ entries
  local dir="$1" max=0 n base
  if [ -d "$dir" ]; then
    for d in "$dir"/[0-9][0-9]-*/ "$dir"/__[0-9][0-9]-*__/; do
      [ -d "$d" ] || continue
      base=$(basename "$d"); base=${base#__}; n=${base%%-*}; n=$((10#$n))
      [ "$n" -gt "$max" ] && max=$n
    done
  fi
  printf "%02d" $((max + 1))
}

next_num_file() {   # next NN among NN-<slug>.md files in $1 (candidates have their own sequence)
  local dir="$1" max=0 n base
  if [ -d "$dir" ]; then
    for f in "$dir"/[0-9][0-9]-*.md; do [ -f "$f" ] || continue
      base=$(basename "$f"); n=${base%%-*}; n=$((10#$n)); [ "$n" -gt "$max" ] && max=$n
    done
  fi
  printf "%02d" $((max + 1))
}

slugify() {   # item text -> stable key: lowercase, non-alnum -> '-', squeeze/trim '-'
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

read_supersedes() {   # $1=arc.md path -> the supersedes: value (prev: accepted as read-alias), '__' stripped
  local v
  v=$(grep -m1 -E '^(supersedes|prev):' "$1" 2>/dev/null \
        | sed -E 's/^(supersedes|prev):[[:space:]]*//' || true)
  v="${v#__}"; v="${v%__}"; echo "$v"
}

read_closes() {   # $1=arc.md path -> the closes: value (uncommented only), or empty
  grep -m1 -E '^closes:' "$1" 2>/dev/null | sed -E 's/^closes:[[:space:]]*//' || true
}

goal_item_keys() {   # $1=goal-doc path -> one "key<TAB>text" per checklist item (between ## Checklist and next heading)
  awk '
    /^##[[:space:]]+[Cc]hecklist/ { inlist=1; next }
    inlist && /^##[[:space:]]/    { inlist=0 }
    inlist && /^- \[[ xX]\]/ {
      line=$0
      sub(/^- \[[ xX]\][[:space:]]*/, "", line)        # strip "- [ ] "
      key=""
      if (match(line, /\{#[^}]+\}/)) {                   # 1. explicit {#key} wins
        key=substr(line, RSTART+2, RLENGTH-3)
      } else {                                           # 2. "<key> — <desc>" form: leading slug token is the key
        head=line
        sub(/[[:space:]]*(—|–|--|-)[[:space:]].*/, "", head)
        sub(/[[:space:]]+$/, "", head)
        if (head ~ /^[A-Za-z0-9][A-Za-z0-9-]*$/) key=head
      }                                                  # 3. else: empty -> caller slugifies whole text
      text=line
      gsub(/\{#[^}]+\}/, "", text)
      sub(/[[:space:]]+$/, "", text)
      print key "\t" text
    }
  ' "$1"
}

# Templates. Field KEYS (goal:/status:/closes:/supersedes:) stay English so the parser is language-agnostic;
# only the human placeholder text + headings are localized.
arc_md() {     # $1=path $2=slug $3=lang
  case "${3:-en}" in
    ru) cat > "$1/arc.md" <<EOF
# $2

goal: <одна строка — что закрывает арка>
status: active
# closes: <ключ пункта чеклиста родительской цели, который закрывает эта арка — опционально>
# supersedes: <слаг арки, которую заменяет эта — опционально; алиас: prev:>

## input
<input/… — однострочная суть того, что зашло>

## output → пойнтеры
- <output/... — что наружу>
EOF
    ;;
    es) cat > "$1/arc.md" <<EOF
# $2

goal: <una línea — qué cierra este arco>
status: active
# closes: <clave del ítem del checklist del objetivo padre que cierra este arco — opcional>
# supersedes: <slug del arco que reemplaza este — opcional; alias: prev:>

## input
<input/… — una línea con la esencia de lo que entró>

## output → punteros
- <output/... — qué sale>
EOF
    ;;
    *) cat > "$1/arc.md" <<EOF
# $2

goal: <one line — what this arc closes>
status: active
# closes: <parent-goal checklist-item key this arc completes — optional>
# supersedes: <slug of the arc this one replaces — optional; alias: prev:>

## input
<input/… — one-line gist of what came in>

## output → pointers
- <output/... — what goes outward>
EOF
    ;;
  esac
}

goal_md() {    # $1=path $2=slug $3=lang  (one immutable <slug>-goal.md per goal)
  case "${3:-en}" in
    ru) cat > "$1/$2-goal.md" <<EOF
# $2-goal — <цель>

goal: <цель — одна строка, ≤12 слов; длинная версия идёт в «Где мы сейчас»>
status: active
# supersedes: <слаг цели, чьё намерение заменяет эта — опционально>

## Checklist
<пункты цели — ключ = слаг текста; done-состояние считается из closes: суб-арок, не ставится руками>
- [ ] <первый пункт>

## Где мы сейчас
<узкое горло>
EOF
    ;;
    es) cat > "$1/$2-goal.md" <<EOF
# $2-goal — <objetivo>

goal: <objetivo — una línea, ≤12 palabras; la versión larga va en «Dónde estamos»>
status: active
# supersedes: <slug del objetivo cuya intención reemplaza este — opcional>

## Checklist
<ítems del objetivo — clave = slug del texto; el estado done se computa de closes: de los sub-arcos, no se marca a mano>
- [ ] <primer ítem>

## Dónde estamos
<cuello de botella>
EOF
    ;;
    *) cat > "$1/$2-goal.md" <<EOF
# $2-goal — <goal>

goal: <goal — one line, ≤12 words; the long version goes in "Where we are">
status: active
# supersedes: <slug of the goal whose intent this one pivots from — optional>

## Checklist
<the goal's items — key = slug of the text; done-state is computed from sub-arcs' closes:, never hand-ticked>
- [ ] <first item>

## Where we are
<current bottleneck>
EOF
    ;;
  esac
}

# --- commands --------------------------------------------------------------
cmd_init() {
  local b lang="${1:-}"
  b=$(base_dir)
  if [ -z "$lang" ]; then
    if [ -t 0 ]; then printf "arcs: language for arcs in this project [en/ru/es] (default en): "; read -r lang || true; fi
    lang="${lang:-en}"
  fi
  case "$lang" in en|ru|es) ;; *) echo "arcs: unknown lang '$lang', using en" >&2; lang=en ;; esac
  printf 'lang=%s\nrules=subagents\n' "$lang" > "$b/config"
  [ -f README.md ] || cat > README.md <<EOF
# $(basename "$PWD")

Follows the **arcs** method. Work lives in \`.arcs/\` (meta), kept in: $lang.
- \`.arcs/arcs/\` — one numbered stream: arcs (\`NN-<slug>/\`) and goals (\`NN-@<slug>/\`)
Status: \`arcs status\` · change language: \`arcs lang <en|ru>\`
EOF
  echo "arcs: initialized $b/ (lang=$lang, rules: subagents — toggle in .arcs/config)"
}

cmd_lang() {
  [ -d .arcs ] || die "no .arcs/ here — run: arcs init"
  local code="${1:-}"
  if [ -z "$code" ]; then echo "lang=$(lang_of)"; return; fi
  case "$code" in en|ru|es) ;; *) die "supported langs: en, ru, es" ;; esac
  if [ -f .arcs/config ] && grep -q '^lang=' .arcs/config; then
    local tmp; tmp="$(mktemp)"; sed "s/^lang=.*/lang=$code/" .arcs/config > "$tmp" && mv "$tmp" .arcs/config
  else
    printf 'lang=%s\n' "$code" >> .arcs/config
  fi
  echo "arcs: lang set to $code (existing files unchanged; new arcs/goals use $code)"
}

cmd_new_arc() {
  local goal_slug="" slug b dir nn lang
  if [ "${1:-}" = "-g" ]; then goal_slug="$2"; shift 2; fi
  slug="${1:-}"; [ -n "$slug" ] || die "usage: arcs new-arc [-g <goal-slug>] <slug>"
  b=$(base_dir); lang=$(lang_of)
  if [ -n "$goal_slug" ]; then
    local gdir; gdir=$(ls -d "$b"/arcs/[0-9][0-9]-@"$goal_slug"/ 2>/dev/null | head -1) || true
    [ -n "$gdir" ] || die "goal '$goal_slug' not found in $b/arcs/ (goal dirs are NN-@$goal_slug)"
    dir="${gdir%/}/arcs"
  else
    dir="$b/arcs"
  fi
  nn=$(next_num "$dir")
  mkdir -p "$dir/$nn-$slug"/{input,workspace,output}
  arc_md "$dir/$nn-$slug" "$nn-$slug" "$lang"
  echo "arcs: created $dir/$nn-$slug (input/workspace/output + arc.md, lang=$lang)"
}

cmd_new_goal() {
  local slug="${1:-}" b nn dir lang
  [ -n "$slug" ] || die "usage: arcs new-goal <slug>"
  b=$(base_dir); lang=$(lang_of)
  nn=$(next_num "$b/arcs")          # shared numbering with standalone arcs
  dir="$b/arcs/$nn-@$slug"          # @ marks a goal (arc with a purpose) in the stream
  mkdir -p "$dir"/{input,workspace,output,arcs}
  goal_md "$dir" "$slug" "$lang"        # one immutable <slug>-goal.md per goal
  echo "arcs: created $dir (goal — input/workspace/output/arcs + $slug-goal.md, lang=$lang)"
}

# bash 3.2 (macOS) — no associative arrays. Find the CLOSED sub-arc that closes a given key.
closing_arc_for() {   # $1=goal dir  $2=item-key -> bare slug of the closed sub-arc declaring closes:<key>, or empty
  local gdir="$1" key="$2" sub name
  for sub in "$gdir"arcs/__[0-9][0-9]-*__/arc.md; do [ -f "$sub" ] || continue
    [ "$(read_closes "$sub")" = "$key" ] || continue
    name=$(basename "$(dirname "$sub")"); name="${name#__}"; name="${name%__}"
    echo "$name"; return
  done
}

# split a "key<TAB>text" row -> echo the resolved item key (explicit key, or slugify(text) if key empty).
# (read -r with IFS=tab skips a *leading* tab, so an empty key would swallow the text — split by hand.)
item_key() {   # $1=raw "key<TAB>text" row
  local row="$1" k t
  k="${row%%$'\t'*}"; t="${row#*$'\t'}"
  [ -n "$k" ] && { echo "$k"; return; }
  slugify "$t"
}

goal_progress_badge() {   # $1=goal dir  $2=goal-doc path -> "N/M ✓" over checklist items
  local gdir="$1" gdoc="$2" row key done=0 total=0
  while IFS= read -r row; do
    [ -n "$row" ] || continue
    key="$(item_key "$row")"
    total=$((total+1)); [ -n "$(closing_arc_for "$gdir" "$key")" ] && done=$((done+1))
  done <<< "$(goal_item_keys "$gdoc")"
  printf "%d/%d ✓" "$done" "$total"
}

# Render a goal's sub-stream. $1=goal dir. Uses checklist (computed from sub-arcs' closes:)
# when the goal doc carries a ## Checklist; else just lists the goal's sub-arcs.
render_goal_substream() {   # $1=goal dir  $2=goal-doc path
  field() { grep -m1 -E "^$2:" "$1" 2>/dev/null | sed -E "s/^$2:[[:space:]]*//" || true; }
  local gdir="$1" gdoc="$2" sub name st clo sup items row key arc rendered_keys=""
  items="$(goal_item_keys "$gdoc")"
  if [ -z "$items" ]; then                       # no checklist -> today's raw list
    for sub in "$gdir"arcs/*/arc.md; do [ -f "$sub" ] &&
      printf "      %-32s %-9s %s\n" "$(basename "$(dirname "$sub")")" "[$(field "$sub" status)]" "$(field "$sub" goal)"; done
    return
  fi
  # per-item line: ✓ key → arc (closed sub-arc declares closes:key) | ○ key (open)
  while IFS= read -r row; do
    [ -n "$row" ] || continue
    key="$(item_key "$row")"
    rendered_keys="$rendered_keys $key"
    arc="$(closing_arc_for "$gdir" "$key")"
    if [ -n "$arc" ]; then printf "      ✓ %-30s → %s\n" "$key" "$arc"
    else                   printf "      ○ %-30s\n"      "$key"; fi
  done <<< "$items"
  # non-closing sub-arcs (spikes / superseded) still list, with status + supersedes chain
  for sub in "$gdir"arcs/*/arc.md; do [ -f "$sub" ] || continue
    clo="$(read_closes "$sub")"
    if [ -n "$clo" ]; then case " $rendered_keys " in *" $clo "*) continue ;; esac; fi
    name=$(basename "$(dirname "$sub")"); st="$(field "$sub" status)"; sup="$(read_supersedes "$sub")"
    printf "      %-32s %-9s %s\n" "$name" "[$st]" "${sup:+supersedes $sup}"
  done
}

cmd_status() {
  local b="."; [ -d .arcs ] && b=".arcs"
  field() { grep -m1 -E "^$2:" "$1" 2>/dev/null | sed -E "s/^$2:[[:space:]]*//" || true; }
  [ -d "$b" ] && echo "lang: $( [ -d .arcs ] && lang_of || echo en )"
  if [ -d .arcs ]; then local on; on="$(rules_on | xargs || true)"; [ -n "$on" ] && echo "rules: $on"; fi
  [ -d "$b/arcs" ] || return 0
  echo "STREAM"
  local d nm gdoc badge
  for d in "$b"/arcs/*/; do [ -d "$d" ] || continue
    nm=$(basename "$d")
    gdoc=$(ls "$d"*-goal.md 2>/dev/null | sort | tail -1 || true)   # a goal carries a <slug>-goal.md
    if [ -n "$gdoc" ]; then
      badge=""
      [ -n "$(goal_item_keys "$gdoc")" ] && badge="$(goal_progress_badge "$d" "$gdoc")"
      printf "  %-36s %-9s %s%s\n" "$nm" "[$(field "$gdoc" status)]" "$(field "$gdoc" goal)" "${badge:+   ($badge)}"
      render_goal_substream "$d" "$gdoc"
    elif [ -f "$d/arc.md" ]; then
      printf "  %-36s %-9s %s\n" "$nm" "[$(field "$d/arc.md" status)]" "$(field "$d/arc.md" goal)"
    fi
  done
  if [ -d "$b/candidates" ] && [ -n "$(ls -A "$b/candidates" 2>/dev/null)" ]; then
    echo "CANDIDATES (surfaced arc-candidates — promote with: arcs promote <slug>)"
    local cf frm; for cf in "$b"/candidates/*.md; do [ -f "$cf" ] || continue
      frm=$(field "$cf" from)
      printf "  %-36s %s\n" "$(basename "$cf" .md)" "${frm:+from $frm}"
    done
  fi
}

# --- versioning ------------------------------------------------------------
# Single source of truth lives at repo root: VERSION (current release) and
# MIN_VERSION (breaking floor — installs below this must update). Both bumped
# at release time alongside a matching git tag + CHANGELOG entry.
UPDATE_FLAG=".arcs-update-required"   # written under repo root when the breaking floor is unmet
UPDATE_STAMP=".arcs-update-stamp"     # mtime throttles the once-a-day remote check

read_ver() {   # $1=repo $2=filename -> version (default 0.0.0)
  local f="$1/$2"
  if [ -f "$f" ]; then tr -d '[:space:]' < "$f"; else echo "0.0.0"; fi
}

ver_le() {   # is $1 <= $2 ? (semver) -> exit 0/1
  [ "$1" = "$2" ] && return 0
  [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -1)" = "$1" ]
}

latest_remote_tag() {   # $1=repo -> highest vX.Y.Z tag, sans leading v (empty if none)
  git -C "$1" tag -l 'v*' --sort=-v:refname 2>/dev/null | head -1 | sed 's/^v//'
}

cmd_version() { echo "arcs $(read_ver "$(repo_dir)" VERSION)"; }

cmd_check_update() {   # [--force] [--quiet] — throttled remote check; sets/clears the gate flag
  local force="" quiet="" a repo; repo="$(repo_dir)"
  for a in "$@"; do case "$a" in --force) force=1 ;; --quiet) quiet=1 ;; esac; done
  [ -d "$repo/.git" ] || return 0   # not a clone: nothing to check
  local stamp="$repo/$UPDATE_STAMP" flag="$repo/$UPDATE_FLAG"
  # Network only once/day (unless --force), capped + non-fatal so it never blocks a session.
  if [ -n "$force" ] || [ -z "$(find "$stamp" -mmin -1440 2>/dev/null)" ]; then
    timeout 4 git -C "$repo" fetch --tags --quiet origin 2>/dev/null || true
    touch "$stamp" 2>/dev/null || true
  fi
  local cur latest rmin
  cur="$(read_ver "$repo" VERSION)"
  latest="$(latest_remote_tag "$repo")"
  # Read the breaking floor from the fetched remote (not the local working tree),
  # so a not-yet-pulled breaking release is still visible.
  rmin="$(git -C "$repo" show origin/main:MIN_VERSION 2>/dev/null | tr -d '[:space:]' || true)"; rmin="${rmin:-0.0.0}"
  # Hard floor: current install below the remote-declared minimum.
  if ver_le "$rmin" "$cur"; then
    rm -f "$flag" 2>/dev/null || true
  else
    touch "$flag" 2>/dev/null || true
    [ -n "$quiet" ] || echo "[arcs] BREAKING update required (need ≥ $rmin, have $cur) — run: arcs update"
    return 0
  fi
  # Soft nudge: behind the latest release tag.
  if [ -n "$latest" ] && ! ver_le "$latest" "$cur"; then
    [ -n "$quiet" ] || echo "[arcs] update available: arcs $latest (you have $cur) — run: arcs update"
  fi
}

cmd_update() {
  local repo; repo="$(repo_dir)"
  [ -d "$repo/.git" ] || die "not a git clone: $repo (re-clone from github.com/socaseinpoint/arcs)"
  local before; before="$(read_ver "$repo" VERSION)"
  echo "arcs: updating $repo (have $before)"
  git -C "$repo" pull --ff-only || die "git pull failed in $repo"
  local after; after="$(read_ver "$repo" VERSION)"
  rm -f "$repo/$UPDATE_FLAG" 2>/dev/null || true   # cleared: we're current now
  # re-run the installer so new tooling (skill, hooks) is wired in — idempotent.
  if [ -x "$repo/install.sh" ]; then
    bash "$repo/install.sh" >/dev/null 2>&1 && echo "arcs: tooling re-wired (PATH · skill · hooks)"
  elif [ -d "$HOME/.claude/skills" ]; then
    ln -sfn "$repo/skill" "$HOME/.claude/skills/arcs"
  fi
  if [ "$before" = "$after" ]; then
    echo "arcs: already latest ($after)"
  else
    echo "arcs: $before → $after — see CHANGELOG.md; restart your Claude Code session to reload skill + hooks"
  fi
}

cmd_help() { sed -n '2,4p' "$0" | sed 's/^# \{0,1\}//'; cat <<EOF

  arcs init [en|ru|es]              create .arcs/ + pick the arc language (asks if a TTY)
  arcs lang [en|ru|es]              show or change this project's arc language
  arcs new-arc <slug>               new standalone arc in .arcs/arcs/
  arcs new-arc -g <goal> <slug>     new arc inside a goal
  arcs new-goal <slug>              new goal (NN-@slug) in the shared .arcs/arcs/ stream
  arcs close [-g <goal>] [-f] <slug> mark an arc done: rename NN-slug -> __NN-slug__ (needs non-empty output/; -f overrides)
  arcs reopen [-g <goal>] <slug>    undo a close: __NN-slug__ -> NN-slug
  arcs supersede [-g <goal>] <old> <new>  close old (no output guard) + create new linked by supersedes: + seed input/from-<old>
  arcs rule [list|on|off|add] ...   toggle behavior rules (global bodies, .arcs/config switch)
  arcs candidate <slug> [--from <arc>] [text]  capture a surfaced arc-candidate in .arcs/candidates/
  arcs candidate list               list candidates (also shown by arcs status)
  arcs promote [-g <goal>] <slug>   turn a candidate into a real arc (moves it into the arc's input/)
  arcs status                       print the board
  arcs version                      print the installed arcs version
  arcs check-update                 throttled remote check; nudge if a newer release exists
  arcs update                       git pull the method + re-wire skill/hooks
EOF
}

cmd_rule() {
  [ -d .arcs ] || die "no .arcs/ here — run: arcs init"
  local action="${1:-list}" slug="${2:-}" repo; repo="$(repo_dir)"
  case "$action" in
    list|"")
      # union of global (<repo>/rules) + local (.arcs/rules) names; on/off comes from config
      local names n src
      names=$(for f in "$repo"/rules/*.md .arcs/rules/*.md; do [ -f "$f" ] && basename "$f" .md || true; done | sort -u)
      [ -z "$names" ] && { echo "rules: (none)"; return; }
      for n in $names; do
        src="global"; [ -f ".arcs/rules/$n.md" ] && src="local"
        if rule_is_on "$n"; then printf "  %-20s [on]   (%s)\n" "$n" "$src"
        else printf "  %-20s [off]  (%s)\n" "$n" "$src"; fi
      done ;;
    on|off)
      [ -n "$slug" ] || die "usage: arcs rule $action <slug>"
      [ -n "$(rule_body_path "$slug")" ] || die "rule '$slug' not found (looked in .arcs/rules/ and $repo/rules/)"
      local cur new
      cur="$(rules_on)"
      if [ "$action" = on ]; then
        rule_is_on "$slug" && { echo "arcs: rule '$slug' already on"; return; }
        new="$(printf '%s %s\n' "$cur" "$slug" | xargs | tr ' ' ',')"
      else
        new="$( { printf '%s\n' $cur | grep -vx "$slug" || true; } | xargs | tr ' ' ',')"
      fi
      config_set_rules "$new"
      echo "arcs: rule $slug -> $action  (config: rules=$new)" ;;
    add)
      [ -n "$slug" ] || die "usage: arcs rule add <slug>"
      mkdir -p .arcs/rules; local f=".arcs/rules/$slug.md"
      [ -f "$f" ] && die "local rule '$slug' already exists: $f"
      cat > "$f" <<EOF
# $slug

<describe the behavior an agent must follow when this rule is enabled>
EOF
      echo "arcs: created local rule $f — enable with: arcs rule on $slug" ;;
    *) die "usage: arcs rule [list | on <slug> | off <slug> | add <slug>]" ;;
  esac
}

# resolve the arcs/ dir to search (a goal's arcs/, or the standalone .arcs/arcs/)
_arc_searchdir() {   # $1=goal_slug (may be empty) -> echoes dir or dies
  local b=".arcs" gdir
  if [ -n "${1:-}" ]; then
    gdir=$(ls -d "$b"/arcs/[0-9][0-9]-@"$1"/ 2>/dev/null | head -1) || true
    [ -n "$gdir" ] || die "goal '$1' not found in $b/arcs/ (goal dirs are NN-@$1)"
    echo "${gdir%/}/arcs"
  else echo "$b/arcs"; fi
}

cmd_close() {
  local goal_slug="" force=0 slug="" sd dir name
  while [ $# -gt 0 ]; do
    case "$1" in
      -g)         goal_slug="$2"; shift 2 ;;
      -f|--force) force=1; shift ;;
      *)          slug="$1"; shift ;;
    esac
  done
  [ -n "$slug" ] || die "usage: arcs close [-g <goal>] [-f] <slug>"
  [ -d .arcs ] || die "no .arcs/ here"
  sd=$(_arc_searchdir "$goal_slug")
  dir=$(ls -d "$sd"/[0-9][0-9]-"$slug"/ "$sd"/[0-9][0-9]-@"$slug"/ 2>/dev/null | head -1) || true
  [ -n "$dir" ] || die "open arc/goal '$slug' not found in $sd/ (already closed?)"
  dir="${dir%/}"; name=$(basename "$dir")
  # an arc closes with a self-contained output/ — refuse to close it empty (override: -f)
  if [ "$force" -eq 0 ] && [ -z "$(ls -A "$dir/output" 2>/dev/null)" ]; then
    die "arc '$slug' has an empty output/ — write the result there first (a closed arc must carry a self-contained output). override: arcs close -f $slug"
  fi
  # status lives in the goal status-doc for a goal, else in arc.md
  local sf; sf=$(ls "$dir"/*-goal.md 2>/dev/null | sort | tail -1 || true); [ -n "$sf" ] || sf="$dir/arc.md"
  if [ -f "$sf" ]; then local tmp; tmp="$(mktemp)"; sed -E 's/^status:.*/status: done/' "$sf" > "$tmp" && mv "$tmp" "$sf"; fi
  mv "$dir" "$sd/__${name}__"
  echo "arcs: closed $name -> __${name}__ (status: done)"
}

cmd_reopen() {
  local goal_slug="" slug sd dir name open
  if [ "${1:-}" = "-g" ]; then goal_slug="$2"; shift 2; fi
  slug="${1:-}"; [ -n "$slug" ] || die "usage: arcs reopen [-g <goal>] <slug>"
  [ -d .arcs ] || die "no .arcs/ here"
  sd=$(_arc_searchdir "$goal_slug")
  dir=$(ls -d "$sd"/__[0-9][0-9]-"$slug"__/ "$sd"/__[0-9][0-9]-@"$slug"__/ 2>/dev/null | head -1) || true
  [ -n "$dir" ] || die "closed arc/goal '$slug' not found in $sd/"
  dir="${dir%/}"; name=$(basename "$dir"); open="${name#__}"; open="${open%__}"
  mv "$dir" "$sd/$open"
  local sf; sf=$(ls "$sd/$open"/*-goal.md 2>/dev/null | sort | tail -1 || true); [ -n "$sf" ] || sf="$sd/$open/arc.md"
  if [ -f "$sf" ]; then local tmp; tmp="$(mktemp)"; sed -E 's/^status:.*/status: active/' "$sf" > "$tmp" && mv "$tmp" "$sf"; fi
  echo "arcs: reopened $open"
}

cmd_candidate() {   # surfaced arc-candidates live in .arcs/candidates/NN-<slug>.md (numbered, with a from:)
  [ -d .arcs ] || die "no .arcs/ here — run: arcs init"
  local d=".arcs/candidates"
  if [ "${1:-list}" = list ]; then
    if [ ! -d "$d" ] || [ -z "$(ls -A "$d" 2>/dev/null)" ]; then echo "candidates: (none)"; return; fi
    local f frm; for f in "$d"/*.md; do [ -f "$f" ] || continue
      frm=$(grep -m1 -E '^from:' "$f" 2>/dev/null | sed -E 's/^from:[[:space:]]*//' || true)
      printf "  %-32s %s\n" "$(basename "$f" .md)" "${frm:+from $frm}"
    done; return
  fi
  # capture: arcs candidate <slug> [--from <arc>] [text...]
  local slug="" from="" text=""
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;;
    *) if [ -z "$slug" ]; then slug="$1"; else text="$text $1"; fi; shift ;;
  esac; done
  [ -n "$slug" ] || die "usage: arcs candidate <slug> [--from <arc>] [text]  |  arcs candidate list"
  mkdir -p "$d"; local nn; nn=$(next_num_file "$d"); local f="$d/$nn-$slug.md"
  { printf '# %s\n' "$slug"; [ -n "$from" ] && printf 'from: %s\n' "$from"; printf '\n'
    [ -n "$text" ] && printf '%s\n' "${text# }"; } > "$f"
  echo "arcs: captured candidate $f${from:+ (from $from)} — promote with: arcs promote $nn-$slug"
}

cmd_promote() {   # turn a candidate into a real arc: create arc + move the file into its input/
  [ -d .arcs ] || die "no .arcs/ here"
  local goal_slug="" key="" newslug=""
  while [ $# -gt 0 ]; do case "$1" in
    -g) goal_slug="${2:-}"; shift 2 ;;
    *)  if [ -z "$key" ]; then key="$1"; else newslug="$1"; fi; shift ;;
  esac; done
  [ -n "$key" ] || die "usage: arcs promote [-g <goal>] <candidate NN-or-slug> [<new-arc-slug>]"
  local d=".arcs/candidates" f
  f=$(ls "$d/$key.md" "$d/$key"-*.md "$d"/*-"$key".md 2>/dev/null | head -1) || true
  [ -n "$f" ] && [ -f "$f" ] || die "candidate '$key' not found in $d/"
  local base; base=$(basename "$f" .md); local cslug="${base#*-}"
  [ -z "$newslug" ] && newslug="$cslug"
  if [ -n "$goal_slug" ]; then cmd_new_arc -g "$goal_slug" "$newslug"; else cmd_new_arc "$newslug"; fi
  local sd dir; sd=$(_arc_searchdir "$goal_slug")
  dir=$(ls -d "$sd"/[0-9][0-9]-"$newslug"/ 2>/dev/null | sort | tail -1); dir="${dir%/}"
  [ -n "$dir" ] || die "could not locate the new arc for '$newslug'"
  mv "$f" "$dir/input/$base.md"
  echo "arcs: promoted candidate '$base' → $dir/input/$base.md (removed from candidates/)"
}

cmd_supersede() {   # close <old> (no output guard) + create <new> in the same scope + link supersedes:
  [ -d .arcs ] || die "no .arcs/ here"
  local goal_slug="" old="" new=""
  while [ $# -gt 0 ]; do case "$1" in
    -g) goal_slug="${2:-}"; shift 2 ;;
    *)  if [ -z "$old" ]; then old="$1"; elif [ -z "$new" ]; then new="$1"; fi; shift ;;
  esac; done
  [ -n "$old" ] && [ -n "$new" ] || die "usage: arcs supersede [-g <goal>] <old-slug> <new-slug>"
  old="${old#__}"; old="${old%__}"               # refs are bare slugs; tolerate __…__
  # 1. close <old> with -f (a superseded arc may legitimately carry no output)
  if [ -n "$goal_slug" ]; then cmd_close -g "$goal_slug" -f "$old"; else cmd_close -f "$old"; fi
  # 2. create <new> in the same scope (same goal substream, or the standalone stream)
  if [ -n "$goal_slug" ]; then cmd_new_arc -g "$goal_slug" "$new"; else cmd_new_arc "$new"; fi
  local sd dir; sd=$(_arc_searchdir "$goal_slug")
  dir=$(ls -d "$sd"/[0-9][0-9]-"$new"/ 2>/dev/null | sort | tail -1); dir="${dir%/}"
  [ -n "$dir" ] || die "could not locate the new arc for '$new'"
  # 3. write supersedes: <old> (real field, after status:) — replaces the commented template line
  local tmp; tmp="$(mktemp)"
  sed -E "/^# supersedes:/d; s|^status:.*|&\nsupersedes: $old|" "$dir/arc.md" > "$tmp" && mv "$tmp" "$dir/arc.md"
  # 4. seed input/from-<old>.md with a one-line pointer back to the superseded arc
  printf '# from %s\n\nThis arc supersedes %s (closed). See __%s__/ for the predecessor.\n' \
    "$old" "$old" "$old" > "$dir/input/from-$old.md"
  echo "arcs: superseded $old → $(basename "$dir") (closed $old, supersedes: $old, seeded input/from-$old.md)"
}

# --- dispatch --------------------------------------------------------------
sub="${1:-help}"; shift || true
case "$sub" in
  init)      cmd_init "$@" ;;
  lang)      cmd_lang "$@" ;;
  new-arc)   cmd_new_arc "$@" ;;
  new-goal)  cmd_new_goal "$@" ;;
  close)     cmd_close "$@" ;;
  reopen)    cmd_reopen "$@" ;;
  supersede) cmd_supersede "$@" ;;
  rule)      cmd_rule "$@" ;;
  candidate) cmd_candidate "$@" ;;
  promote)   cmd_promote "$@" ;;
  status)    cmd_status "$@" ;;
  version|--version|-V) cmd_version ;;
  check-update) cmd_check_update "$@" ;;
  update)    cmd_update "$@" ;;
  help|-h|--help) cmd_help ;;
  *) die "unknown command '$sub' (try: arcs help)" ;;
esac
